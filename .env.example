# OpenRouter - required for live runs. Leave blank in committed files.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Role-specific models - set one per agent.
STRATEGIST_MODEL=
RESEARCHER_MODEL=
REVIEWER_MODEL=
CODER_MODEL=

# Optional reasoning/thinking effort via OpenRouter
# Valid values: none, minimal, low, medium, high, xhigh
AGENT_RESEARCH_REASONING_EFFORT=medium
CODER_REASONING_EFFORT=high

# agent_research runner arguments (can also be passed as CLI flags)
AGENT_RESEARCH_CONFIG=research_config.example.json
AGENT_RESEARCH_GOAL=Find a robust trading strategy that maximizes risk-adjusted performance, improves sharpe_proxy and profit_factor, controls max_drawdown, and satisfies the goal contract
AGENT_RESEARCH_MAX_ITERATIONS=1000
AGENT_RESEARCH_MAX_ITERATIONS_PER_HYPOTHESIS=100
AGENT_RESEARCH_DRY_RUN=false
AGENT_RESEARCH_HYPOTHESES=agent_research/hypotheses.md
AGENT_RESEARCH_REPORTS_DIR=agent_research/reports
AGENT_RESEARCH_LOG_LEVEL=INFO
AGENT_RESEARCH_LOG_FILE=
AGENT_RESEARCH_JSON_LOGS=false
AGENT_RESEARCH_CODE_BUDGET=100

# LangSmith tracing - optional; all required to enable tracing.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=trading-research
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
